{
  "family": "porter-intelligence",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::__ACCOUNT_ID__:role/__EXECUTION_ROLE_NAME__",
  "taskRoleArn": "arn:aws:iam::__ACCOUNT_ID__:role/__TASK_ROLE_NAME__",
  "containerDefinitions": [
    {
      "name": "porter-api",
      "image": "__IMAGE_URI__",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "APP_ENV", "value": "production" },
        { "name": "APP_RUNTIME_MODE", "value": "prod" },
        { "name": "ENABLE_SYNTHETIC_FEED", "value": "false" },
        { "name": "LOG_LEVEL", "value": "INFO" },
        { "name": "PORT", "value": "8000" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:__AWS_REGION__:__ACCOUNT_ID__:secret:porter/prod/DATABASE_URL"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "arn:aws:secretsmanager:__AWS_REGION__:__ACCOUNT_ID__:secret:porter/prod/REDIS_URL"
        },
        {
          "name": "JWT_SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:__AWS_REGION__:__ACCOUNT_ID__:secret:porter/prod/JWT_SECRET_KEY"
        },
        {
          "name": "ENCRYPTION_KEY",
          "valueFrom": "arn:aws:secretsmanager:__AWS_REGION__:__ACCOUNT_ID__:secret:porter/prod/ENCRYPTION_KEY"
        },
        {
          "name": "WEBHOOK_SECRET",
          "valueFrom": "arn:aws:secretsmanager:__AWS_REGION__:__ACCOUNT_ID__:secret:porter/prod/WEBHOOK_SECRET"
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:8000/health || exit 1"
        ],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/porter-intelligence",
          "awslogs-region": "__AWS_REGION__",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "ulimits": [
        {
          "name": "nofile",
          "softLimit": 65536,
          "hardLimit": 65536
        }
      ]
    }
  ]
}
