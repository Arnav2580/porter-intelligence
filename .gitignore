# =============================================================================
# Porter Intelligence Platform — .gitignore
# =============================================================================

# ── Python ───────────────────────────────────────────────────────────────────
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
.eggs/
dist/
build/
.Python

# ── Environment / Secrets ────────────────────────────────────────────────────
# NEVER commit real credentials — use .env.example as the template
.env
.env.local
.env.*.local
!.env.example
!.env.production

# ── Large generated datasets (regenerate with generate_full.py) ──────────────
data/raw/trips_full.csv
data/raw/trips_full_fraud.csv
data/raw/drivers_full.csv
data/raw/customers_full.csv
data/masked/*.csv
data/blind_test/*.csv

# ── Model weight formats not used (committed .json and .pkl are intentional) ─
model/weights/*.ubj

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
log/

# ── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.swp
*.swo

# ── Testing / Coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# ── Frontend ─────────────────────────────────────────────────────────────────
dashboard-ui/node_modules/
dashboard-ui/.env
# .env.production is committed (contains no secrets — only VITE_API_BASE_URL)
dashboard-ui/dist/

# ── Deployment / Hosting ─────────────────────────────────────────────────────
# Netlify local state
.netlify
dashboard-ui/.netlify/

# Vercel local state
.vercel
dashboard-ui/.vercel/

# AWS local provisioning state
infrastructure/aws/state/

# ── Claude Code local settings ───────────────────────────────────────────────
.claude/
.claude/settings.local.json

# ── Archive (local only — internal/sales docs, never public) ─────────────────
_archive/

# ── Trained model weights (core IP — local only) ─────────────────────────────
model/weights/*.pkl
model/weights/*.json
model/weights/*.ubj
# model/weights/README.md is intentionally kept

# ── Raw and synthetic datasets (regenerate locally, never public) ─────────────
data/raw/customers_sample_1000.csv
data/raw/drivers_sample_1000.csv
data/raw/trips_with_fraud_10k.csv
data/raw/evaluation_report.json

# ── Internal docs (handover terms, demo scripts, security runbooks) ───────────
docs/handover/
docs/demo/
docs/security/
docs/runbooks/rotate-secrets.md
docs/runbooks/restore-from-backup.md

# ── Miscellaneous scratch files ──────────────────────────────────────────────
*.tmp
*.bak
*.orig
scratch/
